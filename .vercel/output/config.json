{
  "version": 3,
  "overrides": {},
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<__isr_route>/__nuxt_error)",
      "dest": "/__fallback"
    },
    {
      "src": "/reports/list",
      "dest": "/reports/list"
    },
    {
      "src": "/reports/create",
      "dest": "/reports/create"
    },
    {
      "src": "/reports",
      "dest": "/reports"
    },
    {
      "src": "/manager",
      "dest": "/manager"
    },
    {
      "src": "/kontakt",
      "dest": "/kontakt"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard"
    },
    {
      "src": "/api/updateTask",
      "dest": "/api/updateTask"
    },
    {
      "src": "/api/updateStatus",
      "dest": "/api/updateStatus"
    },
    {
      "src": "/api/updateAnnouncement",
      "dest": "/api/updateAnnouncement"
    },
    {
      "src": "/api/saveReport",
      "dest": "/api/saveReport"
    },
    {
      "src": "/api/saveAnnouncement",
      "dest": "/api/saveAnnouncement"
    },
    {
      "src": "/api/login",
      "dest": "/api/login"
    },
    {
      "src": "/api/getReports",
      "dest": "/api/getReports"
    },
    {
      "src": "/api/getAnnouncements",
      "dest": "/api/getAnnouncements"
    },
    {
      "src": "/api/deleteReport",
      "dest": "/api/deleteReport"
    },
    {
      "src": "/api/deleteAnnouncement",
      "dest": "/api/deleteAnnouncement"
    },
    {
      "src": "/api/adminLogin",
      "dest": "/api/adminLogin"
    },
    {
      "src": "/__nuxt_error",
      "dest": "/__nuxt_error"
    },
    {
      "src": "/",
      "dest": "/index"
    },
    {
      "src": "/__nuxt_island/(?:.*)",
      "dest": "/__nuxt_island/[...]"
    },
    {
      "src": "/(.*)",
      "dest": "/__fallback"
    }
  ]
}